SQLITE_DB_PATH=./attainment.db
PORT=5000
NODE_ENV=production
JWT_SECRET=change_this_to_a_strong_secret
UPLOADS_DIR=./uploads
OUTPUTS_DIR=./outputs
# Stage scripts live in the backend root.
PYTHON_STAGE_DIR=./
# Optional: explicit Python interpreter path if auto-detection is needed.
PYTHON_BIN=./venv/bin/python
# Optional: set full path only if OCR is used.
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# Set your deployed frontend URL here to allow browser requests from Render.
# CORS_ORIGIN=https://your-frontend.onrender.com
# Optional alias for CORS_ORIGIN.
# FRONTEND_URL=https://your-frontend.onrender.com
