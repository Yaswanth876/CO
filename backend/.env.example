SQLITE_DB_PATH=./attainment.db
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here_change_in_production
UPLOADS_DIR=./uploads
OUTPUTS_DIR=./outputs
# Stage scripts are in backend root by default (stage1_qp.py, stage2_marks.py, etc.)
PYTHON_STAGE_DIR=./
# Optional: set explicit interpreter if auto-detection fails (Windows: py or full path)
PYTHON_BIN=
# Optional: set full path if Tesseract is not in PATH (Windows example)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# Optional: comma separated origins for CORS (leave unset to allow LAN browsers)
# CORS_ORIGIN=http://localhost:3000,http://192.168.1.15:3000
